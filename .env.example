# Postgres connection string. Use a free Neon dev branch, a local Docker
# postgres:16, or any Postgres reachable from the dev machine.
#
# For Neon (recommended), copy the "pooled" connection string from the
# Vercel Marketplace integration. The unpooled URL is only needed for
# Prisma CLI commands that hold long-running connections (e.g. migrate).
DATABASE_URL="postgresql://user:pass@localhost:5432/shaadisetu?schema=public"

# Optional — only needed if you want a separate non-pooled URL for
# `prisma migrate dev`. If unset, DATABASE_URL is used for everything.
# DIRECT_DATABASE_URL="postgresql://user:pass@localhost:5432/shaadisetu?schema=public"

# Required — secret used by NextAuth to sign session JWTs. Generate one
# locally with `openssl rand -base64 32`. Without this, every page that
# calls `auth()` will 500.
AUTH_SECRET="generate-with-openssl-rand-base64-32"

# Optional — base URL of the deployment. Used by NextAuth for callback
# URLs in production. In Vercel this is set automatically as VERCEL_URL.
# AUTH_URL="https://your-domain.com"

# Anthropic API key — required for Saathi chat and Astro narrative readings.
# Without it, /astro/match and /astro/reading will return chart data but no
# written interpretation.
# ANTHROPIC_API_KEY="sk-ant-..."

# Prokerala astrology API credentials. If absent (or STUB_ASTRO=true),
# /astro endpoints return deterministic sample data so the UI works without
# a paid account. Sign up at https://api.prokerala.com to get real keys.
# PROKERALA_CLIENT_ID=""
# PROKERALA_CLIENT_SECRET=""
# STUB_ASTRO="true"
